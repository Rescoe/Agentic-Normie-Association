# ─── Chain / RPC ───────────────────────────────────────────────
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
ETH_MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# ─── Deployer ──────────────────────────────────────────────────
# Private key of the deploying wallet (never commit this)
DEPLOYER_PRIVATE_KEY=0x...

# ─── Relayer ───────────────────────────────────────────────────
# Private key used by the backend to sign attestations
# Generate a dedicated wallet for this — NEVER share
RELAYER_PRIVATE_KEY=0x...
# Corresponding public address (goes into AssociationCore constructor)
RELAYER_ADDRESS=0x...

# ─── Contracts (filled after deploy) ───────────────────────────
ASSOCIATION_CORE_ADDRESS=0x...
CONSTITUENT_ASSEMBLY_ADDRESS=0x...
FACTORY_REGISTRY_ADDRESS=0x...
WORK_REGISTRY_ADDRESS=0x...

# ─── Normies API ───────────────────────────────────────────────
NORMIES_API_BASE_URL=https://api.normies.art
# Normies ERC-721 contract on Ethereum mainnet
NORMIES_CONTRACT_ADDRESS=0x...
NORMIES_CHAIN_ID=1

# ─── Frontend (public, safe to expose) ─────────────────────────
NEXT_PUBLIC_CHAIN=baseSepolia
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=YOUR_WALLETCONNECT_PROJECT_ID
NEXT_PUBLIC_ASSOCIATION_CORE_ADDRESS=0x...
NEXT_PUBLIC_CONSTITUENT_ASSEMBLY_ADDRESS=0x...
NEXT_PUBLIC_WORK_REGISTRY_ADDRESS=0x...

# ─── IPFS / Pinata ─────────────────────────────────────────────
PINATA_API_KEY=...
PINATA_API_SECRET=...
PINATA_JWT=...

# ─── Misc ──────────────────────────────────────────────────────
BASESCAN_API_KEY=...
REPORT_GAS=false
