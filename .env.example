# ─── Chain / RPC ────────────────────────────────────────────────────────────
# RPCs pour les lectures on-chain côté serveur (chainReader.ts, normiesOwnership.ts)
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
ETH_MAINNET_RPC_URL=https://eth.llamarpc.com

# ─── Relayer ────────────────────────────────────────────────────────────────
# Wallet dont la clé privée est utilisée côté backend pour signer les attestations EIP-712.
# Peut être le même que le wallet déployeur pour le MVP.
# Générer : node -e "const {Wallet}=require('ethers'); const w=Wallet.createRandom(); console.log(w.privateKey, w.address)"
RELAYER_PRIVATE_KEY=0x_VOTRE_CLE_PRIVEE_ICI
RELAYER_ADDRESS=0x_VOTRE_ADRESSE_RELAYER

# ─── Contrats (à remplir après déploiement) ──────────────────────────────────
# Adresses obtenues après npm run deploy:base ou déploiement via ton app
ASSOCIATION_CORE_ADDRESS=0x218a2C38a16F81DcC944872264d79606b1DB1C40
CONSTITUENT_ASSEMBLY_ADDRESS=0xF06079eb31cF11122C67DcD986354c3bbF0df8a2
WORK_REGISTRY_ADDRESS=0x68cBD92b0a1bcB737364945F22522BdD4324EeCE
FACTORY=0xCB440879cb709aC4176B1e098B26fd350232e670

# ─── API Normies ─────────────────────────────────────────────────────────────
# Optionnel : override de l'URL de base (défaut = https://api.normies.art)
NORMIES_API_BASE_URL=https://api.normies.art
# Adresse du contrat ERC-721 Normies sur Ethereum mainnet
# Utilisé en fallback RPC si l'API Normies est down — non bloquant si laissé vide
NORMIES_CONTRACT_ADDRESS=0x9Eb6E2025B64f340691e424b7fe7022fFDE12438

# ─── Frontend (NEXT_PUBLIC_ = exposé côté client, ne pas y mettre de secrets) ─
# "base" pour mainnet, tout autre valeur = Base Sepolia
NEXT_PUBLIC_CHAIN=base
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=YOUR_WALLETCONNECT_PROJECT_ID
NEXT_PUBLIC_ASSOCIATION_CORE_ADDRESS=0x218a2C38a16F81DcC944872264d79606b1DB1C40
NEXT_PUBLIC_CONSTITUENT_ASSEMBLY_ADDRESS=0xF06079eb31cF11122C67DcD986354c3bbF0df8a2
NEXT_PUBLIC_WORK_REGISTRY_ADDRESS=0x68cBD92b0a1bcB737364945F22522BdD4324EeCE

# ─── Misc ────────────────────────────────────────────────────────────────────
# Optionnel : vérification automatique sur Basescan après déploiement
BASESCAN_API_KEY=...
